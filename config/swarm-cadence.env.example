# Example local config for `swarm-cadence source probe`.
# Copy to a git-ignored path such as ./.swarm-cadence.env and replace placeholders locally.
# Never commit real tokens, cookies, wsid values, or browser-session material.

# v2 OAuth adapter for account label `julian`
SWARM_CADENCE_JULIAN_V2_ACCESS_TOKEN=replace-with-oauth-access-token
SWARM_CADENCE_JULIAN_V2_CLIENT_ID=replace-with-developer-app-client-id
SWARM_CADENCE_JULIAN_V2_CLIENT_SECRET=replace-with-developer-app-secret-if-issued
SWARM_CADENCE_JULIAN_V2_REDIRECT_URI=http://localhost:17342/foursquare/callback

# Swarm web historysearch fallback adapter for account label `julian`
SWARM_CADENCE_JULIAN_HISTORYSEARCH_USERID=replace-with-swarm-web-userid
SWARM_CADENCE_JULIAN_HISTORYSEARCH_WSID=replace-with-swarm-web-wsid
SWARM_CADENCE_JULIAN_HISTORYSEARCH_OAUTH_TOKEN=replace-with-swarm-web-oauth-token
SWARM_CADENCE_JULIAN_HISTORYSEARCH_COOKIE=replace-with-cookie-only-if-needed
